# ---------------------------------------------------------------------------
# RAG Knowledge Assistant — configuration
# Copy to `.env` and adjust. The defaults run fully offline (no API keys).
# ---------------------------------------------------------------------------

# --- Embeddings -------------------------------------------------------------
# "hash"   -> deterministic offline embeddings (default; no key required)
# "openai" -> OpenAI text-embedding-3-small (recommended for real retrieval)
EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=sk-...

# --- LLM (answer generation) ------------------------------------------------
# "echo"      -> deterministic offline answer (default; no key required)
# "anthropic" -> Claude via the Anthropic API (recommended)
LLM_PROVIDER=echo
ANTHROPIC_MODEL=claude-opus-4-8
# ANTHROPIC_API_KEY=sk-ant-...

# --- Retrieval / chunking ---------------------------------------------------
CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K=4
MAX_TOKENS=1024

# --- Storage ----------------------------------------------------------------
STORAGE_DIR=storage

# ---------------------------------------------------------------------------
# To run with real models, set for example:
#   EMBEDDING_PROVIDER=openai   OPENAI_API_KEY=sk-...
#   LLM_PROVIDER=anthropic      ANTHROPIC_API_KEY=sk-ant-...
# ---------------------------------------------------------------------------
