# ---------------------------------------------------------------------------
# RAG Knowledge Assistant — configuration
# Copy to `.env` and adjust. The defaults run fully offline (no API keys).
# ---------------------------------------------------------------------------

# --- Embeddings -------------------------------------------------------------
# "hash"   -> deterministic offline embeddings (default; no key required)
# "gemini" -> Google Gemini embeddings (recommended; free tier)
# "openai" -> OpenAI text-embedding-3-small
EMBEDDING_PROVIDER=hash
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# GEMINI_EMBEDDING_DIM=768
# EMBEDDING_MODEL=text-embedding-3-small     # OpenAI model (EMBEDDING_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# --- LLM (answer generation) ------------------------------------------------
# "echo"      -> deterministic offline answer (default; no key required)
# "gemini"    -> Google Gemini (recommended; free tier)
# "anthropic" -> Claude via the Anthropic API
LLM_PROVIDER=echo
GEMINI_MODEL=gemini-flash-latest
# GEMINI_THINKING_BUDGET=0     # 0 disables thinking (fast/cheap); -1 = dynamic
# ANTHROPIC_MODEL=claude-opus-4-8

# --- API keys ---------------------------------------------------------------
# One free Gemini key powers BOTH the LLM and embeddings above.
# Get one at https://aistudio.google.com/apikey
# GEMINI_API_KEY=...
# ANTHROPIC_API_KEY=sk-ant-...

# --- Retrieval / chunking ---------------------------------------------------
CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K=4
MAX_TOKENS=1024

# --- Storage ----------------------------------------------------------------
STORAGE_DIR=storage

# --- Email: sign-up verification codes (optional SMTP) ----------------------
# When set, the sign-up flow emails a 6-digit code to the address being
# registered. Leave unset to keep the demo fallback (the code is shown in the UI).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=you@gmail.com          # defaults to SMTP_USER when unset
# SMTP_STARTTLS=true

# --- Auth: real Google / GitHub OAuth ---------------------------------------
# Leave unset to keep the popup's social buttons in demo mode. Set both the id
# and secret for a provider to enable real sign-in. See README for the console
# setup + redirect URIs.
# SESSION_SECRET=change-me-to-a-long-random-string
# OAUTH_REDIRECT_BASE=https://your-app.vercel.app   # exact public URL (optional; derived from request if unset)
# GOOGLE_CLIENT_ID=...apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=...
# GITHUB_CLIENT_ID=...
# GITHUB_CLIENT_SECRET=...

# ---------------------------------------------------------------------------
# To run fully free on Gemini (one key powers both), set:
#   EMBEDDING_PROVIDER=gemini
#   LLM_PROVIDER=gemini
#   GEMINI_API_KEY=...
# ---------------------------------------------------------------------------
